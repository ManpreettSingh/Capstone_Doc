      </thead>
      <tbody>
        ${HW.map((h,i)=>`<tr style="background:${i%2===0?"var(--white)":"var(--off)"}">
          <td style="font-weight:600;color:var(--navy)">${h.item}</td>
          <td style="font-size:12px">${h.spec}</td>
